# Server
PORT=3000
NODE_ENV=development

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# File paths
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output

# Logging
LOG_LEVEL=dev

# File upload limits (bytes)
MAX_FILE_SIZE=10485760

# CORS (comma-separated origins or '*')
CORS_ORIGINS=*

# Billing divisor: 'actual' = use actual days in month, '30' = always divide by 30
BILLING_DIVISOR=30

# Shared secret for the HR Ops (HR1) "Export to Billing Gen" push. Must match
# BILLINGGEN_INTEGRATION_KEY set in the HR Ops app. Leave blank to disable.
INTEGRATION_API_KEY=
