# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./database/billing.db

# File paths
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output

# Logging
LOG_LEVEL=dev

# File upload limits (bytes)
MAX_FILE_SIZE=10485760

# GST
DEFAULT_GST_PERCENT=18

# CORS (comma-separated origins or '*')
CORS_ORIGINS=*

# Billing divisor: 'actual' = use actual days in month, '30' = always divide by 30
BILLING_DIVISOR=actual
